{
  "name": "meshi",
  "private": true,
  "packageManager": "pnpm@11.9.0",
  "type": "module",
  "scripts": {
    "start": "tsx src/index.ts",
    "dev": "tsx watch src/index.ts",
    "build": "tsup src/index.ts src/db/migrate.ts --format esm --out-dir dist --clean",
    "db:up": "docker compose up -d postgres",
    "db:down": "docker compose down",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "seed": "tsx scripts/seed.ts",
    "lint": "eslint .",
    "format:eslint": "eslint --fix .",
    "format:prettier": "prettier --write .",
    "format": "conc -m 1 pnpm:format:eslint pnpm:format:prettier",
    "test": "conc pnpm:test:type pnpm:test:unit",
    "test:type": "tsc --noEmit",
    "test:unit": "vitest run"
  },
  "devDependencies": {
    "@commitlint/cli": "21.2.0",
    "@eslint/eslintrc": "3.3.5",
    "@fohte/eslint-config": "0.3.5",
    "@tsconfig/node-lts": "24.0.0",
    "@tsconfig/strictest": "2.0.8",
    "@types/node": "24.13.2",
    "concurrently": "10.0.3",
    "drizzle-kit": "0.31.10",
    "eslint": "10.6.0",
    "prettier": "3.9.4",
    "tsup": "8.5.1",
    "tsx": "4.22.4",
    "typescript": "6.0.3",
    "vitest": "4.1.9"
  },
  "dependencies": {
    "@fohte/service-kit": "0.1.4",
    "@hono/node-server": "2.0.8",
    "@langchain/core": "1.2.1",
    "@modelcontextprotocol/sdk": "1.29.0",
    "@opentelemetry/api": "1.9.1",
    "@opentelemetry/auto-instrumentations-node": "0.77.0",
    "@opentelemetry/exporter-trace-otlp-proto": "0.219.0",
    "@opentelemetry/resources": "2.8.0",
    "@opentelemetry/sdk-node": "0.219.0",
    "@opentelemetry/sdk-trace-base": "2.8.0",
    "@opentelemetry/semantic-conventions": "1.41.1",
    "@sentry/node": "10.62.0",
    "@sentry/opentelemetry": "10.62.0",
    "drizzle-orm": "0.45.2",
    "hono": "4.12.27",
    "postgres": "3.4.9",
    "zod": "4.4.3"
  }
}
